// === xxh64_common.z ===
use core::mem;
pub const CHUNK_SIZE: i64 = mem::size_of::<i64>() * 4;
pub const PRIME_1: i64 = 0x9E3779B185EBCA87;
pub const PRIME_2: i64 = 0xC2B2AE3D27D4EB4F;
pub const PRIME_3: i64 = 0x165667B19E3779F9;
pub const PRIME_4: i64 = 0x85EBCA77C2B2AE63;
pub const PRIME_5: i64 = 0x27D4EB2F165667C5;

pub fn round(acc: i64, input: i64) -> i64 {
    return (acc + (input * PRIME_2)).rotate_left(31) * PRIME_1;
}

pub fn merge_round(acc: i64, val: i64) -> i64 {
    return (acc ^ round(0, val)) * PRIME_1 + PRIME_4;
}

pub fn avalanche(input: i64) -> i64 {
    let mut h = input ^ (input >> 33);
    h = h * PRIME_2;
    h = h ^ (h >> 29);
    h = h * PRIME_3;
    h = h ^ (h >> 32);
    return h;
}

// === xxh64.z ===
pub fn xxh64(data: i64, len: i64, seed: i64) -> i64 {
    if (len >= CHUNK_SIZE) {
        let v1 = seed + PRIME_1 + PRIME_2;
        let v2 = seed + PRIME_2;
        let v3 = seed;
        let v4 = seed - PRIME_1;
        let mut i: i64 = 0;
        while (i + 32 <= len) {
            let d1 = os_load(data + i);
            let d2 = os_load(data + i + 8);
            let d3 = os_load(data + i + 16);
            let d4 = os_load(data + i + 24);
            v1 = round(v1, d1);
            v2 = round(v2, d2);
            v3 = round(v3, d3);
            v4 = round(v4, d4);
            i = i + 32;
        }
        let mut h = v1.rotate_left(1) + v2.rotate_left(7) + v3.rotate_left(12) + v4.rotate_left(18);
        h = merge_round(h, v1);
        h = merge_round(h, v2);
        h = merge_round(h, v3);
        h = merge_round(h, v4);
        // Process remaining
        while (i + 8 <= len) {
            h = os_load(data + i);
            h = round(0, h);
            h = h.rotate_left(27) * PRIME_1 + PRIME_4;
            i = i + 8;
        }
        while (i + 4 <= len) {
            h = h ^ (os_load_32(data + i) * PRIME_1);
            h = h.rotate_left(23) * PRIME_2 + PRIME_3;
            i = i + 4;
        }
        while (i < len) {
            h = h ^ (os_load_8(data + i) * PRIME_5);
            h = h.rotate_left(11) * PRIME_1;
            i = i + 1;
        }
        h = h + len;
        return avalanche(h);
    } else {
        let mut h = seed + PRIME_5 + len;
        let mut i: i64 = 0;
        while (i + 8 <= len) {
            h = h ^ round(0, os_load(data + i));
            h = h.rotate_left(27) * PRIME_1 + PRIME_4;
            i = i + 8;
        }
        while (i + 4 <= len) {
            h = h ^ (os_load_32(data + i) * PRIME_1);
            h = h.rotate_left(23) * PRIME_2 + PRIME_3;
            i = i + 4;
        }
        while (i < len) {
            h = h ^ (os_load_8(data + i) * PRIME_5);
            h = h.rotate_left(11) * PRIME_1;
            i = i + 1;
        }
        return avalanche(h);
    }
}

// === main test ===
fn main() -> i64 {
    // Test: hash "hello"
    let data = os_alloc(5);
    os_store_8(data, 'h');
    os_store_8(data + 1, 'e');
    os_store_8(data + 2, 'l');
    os_store_8(data + 3, 'l');
    os_store_8(data + 4, 'o');
    
    let h = xxh64(data, 5, 0);
    os_log("xxh64(hello, 5, 0) = 0x");
    os_log_hex(h);
    os_log("\n");
    
    return 0;
}
