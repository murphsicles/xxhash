use @crypto/xxhash::xxh64;
use @crypto/xxhash::xxh32;

fn main() -> i64 {
    // Test xxh64 with some known test vectors
    let data: &[u8] = "hello";
    let h64 = xxh64::xxh64(data, 0);
    // xxh64("hello", seed=0) = 0x4B3A0B2E5F97D7B4 or similar
    os::log("xxh64(hello, 0) = ");
    os::log_hex(h64);
    os::log("\n");
    
    let h32 = xxh32::xxh32(data, 0);
    os::log("xxh32(hello, 0) = ");
    os::log_hex(h32);
    os::log("\n");
    
    // Test empty input
    let empty: &[u8] = "";
    let h = xxh64::xxh64(empty, 0);
    os::log("xxh64(empty, 0) = ");
    os::log_hex(h);
    os::log("\n");
    
    return 0;
}
